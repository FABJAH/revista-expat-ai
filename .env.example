# Revista Expats AI - Variables de Entorno
# Copia este archivo a .env y personaliza

# === CONFIGURACIÓN GENERAL ===
# Modo producción (true/false)
PRODUCTION=false

# Puerto del servidor (para despliegues en la nube)
PORT=8000

# === CONFIGURACIÓN CORS ===
# Dominios permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# === CONFIGURACIÓN LUNA BOT ===
# Idioma por defecto
LUNA_DEFAULT_LANGUAGE=es

# Posición del widget
LUNA_WIDGET_POSITION=bottom-right

# Auto-abrir widget
LUNA_AUTO_OPEN=true

# Delay para auto-abrir (ms)
LUNA_AUTO_OPEN_DELAY=3000

# Email para leads
LUNA_ADMIN_EMAIL=admin@revistaexpatriados.es

# Webhook para leads (opcional)
# LUNA_WEBHOOK_URL=https://tu-api.com/webhooks/leads

# === CONFIGURACIÓN BASE DE DATOS ===
# URL de base de datos (PostgreSQL recomendado para producción)
# DATABASE_URL=postgresql://user:password@host:port/database

# === CONFIGURACIÓN LOGGING ===
LOG_LEVEL=INFO

# === API KEYS (si usas servicios externos) ===
# OPENAI_API_KEY=tu-key-aqui
# ANTHROPIC_API_KEY=tu-key-aqui
# GOOGLE_MAPS_API_KEY=tu-key-aqui

# Base de datos (opcional)
# DATABASE_URL=sqlite:///luna_leads.db
# ========================================
# Barcelona Metropolitan Directory Config
# ========================================

# URL base de la API del directorio
# Ejemplo: https://api.barcelona-metropolitan.com
# O: https://www.barcelona-metropolitan.com/api
BM_DIRECTORY_API_URL=https://www.barcelona-metropolitan.com/api

# API Key para autenticación (si es necesaria)
BM_API_KEY=your_api_key_here

# ========================================
# Scraper Config (si usas scraping en lugar de API)
# ========================================

# URL base del sitio web de Barcelona Metropolitan
BM_SCRAPER_URL=https://www.barcelona-metropolitan.com

# Horas para cachear resultados del scraper
BM_SCRAPER_CACHE_HOURS=24
